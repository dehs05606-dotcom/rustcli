# RustCLI environment overrides (optional — defaults work out of box)
# API key is built-in, no config needed to start.

# Provider: opencode | ollama | openai | openrouter | anthropic | gemini | nvidia
AIA_PROVIDER=opencode
AIA_MODEL=deepseek-v4-flash-free

# Effort: fast | balanced | deep | max
AIA_EFFORT=max
AIA_AUTO_APPLY=true
AIA_MAX_OUTPUT_TOKENS=200000
AIA_REQUEST_TIMEOUT_SECS=4000
AIA_MAX_TOOL_ITERATIONS=24
AIA_CONTEXT_SCAN_FILES=2000
AIA_TEMPERATURE=0.12

# Ollama local
AIA_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=
AIA_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
OPENROUTER_API_KEY=
AIA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenCode Zen (API key built-in, override if needed)
OPENCODE_API_KEY=
AIA_OPENCODE_BASE_URL=https://opencode.ai/zen/v1/chat/completions

# NVIDIA NIM / integrate API
NVIDIA_API_KEY=
AIA_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
